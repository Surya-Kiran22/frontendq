# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/placement-system

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRE=7d

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=placement-system-uploads

# Email Configuration (for OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=suryalbrcem9@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@placement-system.com

# Client URL
CLIENT_URL=http://localhost:3000

# Backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# Demo Mode Configuration
DEMO_MODE=true

# Note: Create a .env file from this example and update with your actual values
# The .env file is already in .gitignore for security
